{
  "name": "protoutil pubsub v1",
  "section": [
    {
      "name": "CloudEvent materialization",
      "test": [
        {
          "name": "publish wraps protobuf payload in CloudEvent",
          "kind": "CASE_KIND_CLOUDEVENT_MATERIALIZATION",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedEvent": {
            "source": "conformance-service",
            "specversion": "1.0",
            "type": "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened",
            "dataschema": "protoutil.pubsub.testing.v1.AlphaEvent",
            "datacontenttype": "application/protobuf",
            "dataJson": "{\"eventId\":\"evt_123\",\"name\":\"alpha\"}"
          }
        },
        {
          "name": "metadata propagates as extension attributes",
          "kind": "CASE_KIND_METADATA_PROPAGATION",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service",
              "metadata": [
                {
                  "key": "tenantid",
                  "stringValue": "t1"
                }
              ]
            }
          },
          "expectedEvent": {
            "metadata": [
              {
                "key": "tenantid",
                "stringValue": "t1"
              }
            ]
          }
        },
        {
          "name": "metadata preserves typed CloudEvent attributes",
          "kind": "CASE_KIND_METADATA_PROPAGATION",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service",
              "metadata": [
                {
                  "key": "tenantid",
                  "stringValue": "t1"
                },
                {
                  "key": "attempt",
                  "intValue": 2
                },
                {
                  "key": "dryrun",
                  "boolValue": true
                }
              ]
            }
          },
          "expectedEvent": {
            "metadata": [
              {
                "key": "tenantid",
                "stringValue": "t1"
              },
              {
                "key": "attempt",
                "intValue": 2
              },
              {
                "key": "dryrun",
                "boolValue": true
              }
            ]
          }
        },
        {
          "name": "beta payload packs its own protobuf schema",
          "kind": "CASE_KIND_CLOUDEVENT_MATERIALIZATION",
          "publish": {
            "method": "betaHappened",
            "payload": {
              "eventId": "evt_456",
              "detail": "beta-detail",
              "active": true
            },
            "options": {
              "source": "beta-service"
            }
          },
          "expectedEvent": {
            "source": "beta-service",
            "specversion": "1.0",
            "type": "protoutil.pubsub.testing.v1.ConformanceEvents.BetaHappened",
            "dataschema": "protoutil.pubsub.testing.v1.BetaEvent",
            "datacontenttype": "application/protobuf",
            "dataJson": "{\"eventId\":\"evt_456\",\"detail\":\"beta-detail\",\"active\":true}"
          }
        }
      ]
    },
    {
      "name": "Resolution precedence",
      "test": [
        {
          "name": "topic explicit beats method typename",
          "kind": "CASE_KIND_TOPIC_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "topic": "custom.topic",
              "source": "conformance-service"
            }
          },
          "expectedTopic": "custom.topic"
        },
        {
          "name": "publisher default topic applies to method",
          "kind": "CASE_KIND_TOPIC_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedTopic": "publisher.default.topic",
          "publisherDefaults": {
            "topic": "publisher.default.topic"
          }
        },
        {
          "name": "publisher method topic applies to matching method",
          "kind": "CASE_KIND_TOPIC_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedTopic": "publisher.alpha.topic",
          "publisherDefaults": {
            "topicByMethod": [
              {
                "method": "alphaHappened",
                "topic": "publisher.alpha.topic"
              }
            ]
          }
        },
        {
          "name": "topic falls back to method typename",
          "kind": "CASE_KIND_TOPIC_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedTopic": "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened"
        },
        {
          "name": "type explicit beats method typename",
          "kind": "CASE_KIND_TYPE_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "type": "com.example.conformance.AlphaHappened.v2",
              "source": "conformance-service"
            }
          },
          "expectedValue": "com.example.conformance.AlphaHappened.v2"
        },
        {
          "name": "type stays semantic when topic is overridden",
          "kind": "CASE_KIND_CLOUDEVENT_MATERIALIZATION",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "topic": "custom.topic",
              "source": "conformance-service"
            }
          },
          "expectedEvent": {
            "type": "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened"
          },
          "expectedTopic": "custom.topic"
        },
        {
          "name": "type falls back to method typename",
          "kind": "CASE_KIND_TYPE_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedValue": "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened"
        },
        {
          "name": "source explicit beats client default",
          "kind": "CASE_KIND_SOURCE_PRECEDENCE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "call-source"
            }
          },
          "sourceDefaults": {
            "clientDefault": "client-source",
            "transportDefault": "transport-source"
          },
          "expectedValue": "call-source"
        },
        {
          "name": "source falls back through client transport library",
          "kind": "CASE_KIND_SOURCE_PRECEDENCE",
          "sourceDefaults": {
            "clientDefault": "client-source",
            "transportDefault": "transport-source",
            "libraryDefault": "protoutil.pubsub"
          },
          "expectedValue": "client-source"
        },
        {
          "name": "source falls back to transport default",
          "kind": "CASE_KIND_SOURCE_PRECEDENCE",
          "sourceDefaults": {
            "transportDefault": "transport-source",
            "libraryDefault": "protoutil.pubsub"
          },
          "expectedValue": "transport-source"
        },
        {
          "name": "source falls back to library default",
          "kind": "CASE_KIND_SOURCE_PRECEDENCE",
          "sourceDefaults": {
            "libraryDefault": "protoutil.pubsub"
          },
          "expectedValue": "protoutil.pubsub"
        }
      ]
    },
    {
      "name": "Subscription resolution",
      "test": [
        {
          "name": "router string topic resolves subscribe topic",
          "kind": "CASE_KIND_SUBSCRIBE_RESOLUTION",
          "routerConfig": {
            "topic": "router.shared.topic"
          },
          "expectedSubscribe": {
            "topics": [
              "router.shared.topic"
            ],
            "deadLetterTopic": "protoutil.pubsub.testing.v1.ConformanceEvents.__deadletter"
          }
        },
        {
          "name": "router method topic resolves subscribe topic",
          "kind": "CASE_KIND_SUBSCRIBE_RESOLUTION",
          "routerConfig": {
            "topicByMethod": [
              {
                "method": "alphaHappened",
                "topic": "router.alpha.topic"
              }
            ]
          },
          "expectedSubscribe": {
            "topics": [
              "router.alpha.topic",
              "protoutil.pubsub.testing.v1.ConformanceEvents.BetaHappened"
            ],
            "deadLetterTopic": "protoutil.pubsub.testing.v1.ConformanceEvents.__deadletter"
          }
        },
        {
          "name": "dead letter topic defaults from service type",
          "kind": "CASE_KIND_SUBSCRIBE_RESOLUTION",
          "expectedSubscribe": {
            "topics": [
              "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened",
              "protoutil.pubsub.testing.v1.ConformanceEvents.BetaHappened"
            ],
            "deadLetterTopic": "protoutil.pubsub.testing.v1.ConformanceEvents.__deadletter"
          }
        },
        {
          "name": "dead letter topic override resolves on subscribe",
          "kind": "CASE_KIND_SUBSCRIBE_RESOLUTION",
          "routerConfig": {
            "deadLetterTopic": "billing.__deadletter"
          },
          "expectedSubscribe": {
            "topics": [
              "protoutil.pubsub.testing.v1.ConformanceEvents.AlphaHappened",
              "protoutil.pubsub.testing.v1.ConformanceEvents.BetaHappened"
            ],
            "deadLetterTopic": "billing.__deadletter"
          }
        }
      ]
    },
    {
      "name": "Routing and disposition",
      "test": [
        {
          "name": "route by CloudEvent type",
          "kind": "CASE_KIND_ROUTE_BY_TYPE",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service"
            }
          },
          "expectedDisposition": {
            "kind": "ack"
          }
        },
        {
          "name": "successful handler acks",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "ack"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_SUCCESS"
        },
        {
          "name": "explicit ack action acks",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "ack"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_ACK"
        },
        {
          "name": "explicit reject action rejects",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "reject"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_REJECT"
        },
        {
          "name": "explicit dead letter action dead letters",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "dead_letter"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_DEAD_LETTER"
        },
        {
          "name": "transient failure retries",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "retry"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_TRANSIENT"
        },
        {
          "name": "invalid input rejects",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "reject"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_INVALID"
        },
        {
          "name": "unrecoverable failure dead letters",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "dead_letter"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_UNRECOVERABLE"
        },
        {
          "name": "unknown route dead letters",
          "kind": "CASE_KIND_DISPOSITION",
          "expectedDisposition": {
            "kind": "dead_letter"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_UNKNOWN_ROUTE"
        },
        {
          "name": "text CloudEvent data rejects",
          "kind": "CASE_KIND_CLOUDEVENT_PARSE_FAILURE",
          "expectedDisposition": {
            "kind": "reject"
          }
        },
        {
          "name": "wrong protobuf payload rejects",
          "kind": "CASE_KIND_CLOUDEVENT_PARSE_FAILURE",
          "publish": {
            "method": "betaHappened",
            "payload": {
              "eventId": "evt_456",
              "detail": "beta-detail",
              "active": true
            }
          },
          "expectedDisposition": {
            "kind": "reject"
          }
        }
      ]
    },
    {
      "name": "Delay",
      "test": [
        {
          "name": "publish carries notBefore",
          "kind": "CASE_KIND_DELAYED_PUBLISH",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service",
              "notBefore": "1970-01-01T00:00:05.000001Z"
            }
          },
          "expectedEvent": {
            "notBefore": "1970-01-01T00:00:05.000001Z"
          }
        },
        {
          "name": "retry carries protobuf Duration",
          "kind": "CASE_KIND_DELAYED_RETRY",
          "expectedDisposition": {
            "kind": "retry",
            "delay": "3s"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_RETRY_DELAY"
        },
        {
          "name": "delayed publish without scheduler fails",
          "kind": "CASE_KIND_DELAYED_PUBLISH",
          "publish": {
            "method": "alphaHappened",
            "payload": {
              "eventId": "evt_123",
              "name": "alpha"
            },
            "options": {
              "source": "conformance-service",
              "notBefore": "1970-01-01T00:00:05Z"
            }
          },
          "transportFeatures": {},
          "expectedErrorContains": "Delayed publish requires a scheduler"
        },
        {
          "name": "delayed retry without scheduler fails",
          "kind": "CASE_KIND_DELAYED_RETRY",
          "expectedDisposition": {
            "kind": "retry",
            "delay": "3s"
          },
          "handlerBehavior": "HANDLER_BEHAVIOR_RETRY_DELAY",
          "transportFeatures": {},
          "expectedErrorContains": "Delayed retry requires a scheduler"
        }
      ]
    }
  ]
}
