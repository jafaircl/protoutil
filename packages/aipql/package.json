{
  "name": "@protoutil/aipql",
  "type": "module",
  "version": "0.3.2",
  "description": "Translate AIP-160 filter expressions into SQL and MongoDB queries.",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jafaircl/protoutil/tree/main/packages/aipql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jafaircl/protoutil.git"
  },
  "bugs": {
    "url": "https://github.com/jafaircl/protoutil/issues"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "protogen": "buf generate"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "dependencies": {
    "@protoutil/aip": "workspace:*",
    "@protoutil/core": "workspace:*"
  }
}
