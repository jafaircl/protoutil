{
  "name": "@protoutil/repo",
  "type": "module",
  "version": "0.3.0",
  "description": "Database-agnostic protobuf resource persistence using AIP patterns.",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jafaircl/protoutil/tree/main/packages/repo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jafaircl/protoutil.git"
  },
  "bugs": {
    "url": "https://github.com/jafaircl/protoutil/issues"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./mongodb": {
      "require": "./dist/mongodb/index.cjs",
      "import": "./dist/mongodb/index.mjs"
    },
    "./mysql": {
      "require": "./dist/mysql/index.cjs",
      "import": "./dist/mysql/index.mjs"
    },
    "./postgres": {
      "require": "./dist/postgres/index.cjs",
      "import": "./dist/postgres/index.mjs"
    },
    "./sqlite": {
      "require": "./dist/sqlite/index.cjs",
      "import": "./dist/sqlite/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:verified": "tsdown && node ./scripts/pack-check.mjs",
    "bench": "node --import tsx src/repository.bench.ts",
    "dev": "tsdown --watch",
    "pack-check": "node ./scripts/pack-check.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build:verified",
    "protogen": "buf generate"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0",
    "pg": ">=8.0.0",
    "mysql2": ">=3.0.0",
    "mongodb": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.11.6",
    "@types/node": "^25.0.3",
    "better-sqlite3": "^12.6.2",
    "mongodb": "^6.16.0",
    "mysql2": "^3.14.0",
    "pg": "^8.13.1",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@protoutil/aip": "workspace:*",
    "@protoutil/aipql": "workspace:*",
    "@protoutil/core": "workspace:*"
  }
}
