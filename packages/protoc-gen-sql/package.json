{
  "name": "@protoutil/protoc-gen-sql",
  "type": "module",
  "version": "0.3.1",
  "description": "A starter for creating a TypeScript package.",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jafaircl/protoutil/tree/main/packages/aip#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jafaircl/protoutil.git"
  },
  "bugs": {
    "url": "https://github.com/jafaircl/protoutil/issues"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "protogen": "buf generate"
  },
  "devDependencies": {
    "@bufbuild/protocompile": "^0.0.1",
    "@bufbuild/protoplugin": "^2.11.0",
    "@types/node": "^25.0.3",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@protoutil/core": "workspace:*"
  }
}
