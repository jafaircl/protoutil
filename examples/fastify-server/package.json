{
  "type": "module",
  "name": "fastify-server",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "./dist/app.cjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "lsof -ti:8080 | xargs kill -9 2>/dev/null; FASTIFY_AUTOLOAD_TYPESCRIPT=1 tsx watch --import tsx/esm src/server.ts",
    "test": "NODE_OPTIONS=\"--import tsx/esm\" vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "protogen": "buf generate",
    "sqlcgen": "sqlc generate",
    "dbgen": "tsx scripts/sqlite-init-db.ts",
    "dbseed": "tsx scripts/sqlite-seed-db.ts",
    "kyselygen": "kysely-codegen --dialect sqlite --url data/library.db --out-file src/gen/kysely/sqlite/types.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-fastify": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@protoutil/aip": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.11",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "module": "./dist/app.mjs",
  "types": "./dist/app.d.cts",
  "exports": {
    "./app": {
      "import": "./dist/app.mjs",
      "require": "./dist/app.cjs"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  }
}
